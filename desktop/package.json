{
  "name": "plant-sim-ide-desktop",
  "version": "1.0.0",
  "description": "Plant Sim IDE - desktop wrapper (Electron)",
  "main": "main.js",
  "author": "zasifbinislam-coder",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win --x64",
    "dist:portable": "electron-builder --win portable --x64"
  },
  "build": {
    "appId": "com.zasbiz.plantsim",
    "productName": "Plant Sim IDE",
    "asar": true,
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "main.js",
      "package.json",
      { "from": "../plant-sim-ide", "to": "plant-sim-ide" }
    ],
    "win": {
      "target": ["nsis", "portable"],
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "Plant Sim IDE"
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "icon": "build/icon.png",
      "category": "Development"
    },
    "mac": {
      "target": "dmg",
      "icon": "build/icon.icns",
      "category": "public.app-category.developer-tools"
    }
  },
  "devDependencies": {
    "electron": "^28.1.0",
    "electron-builder": "^24.9.1"
  }
}
